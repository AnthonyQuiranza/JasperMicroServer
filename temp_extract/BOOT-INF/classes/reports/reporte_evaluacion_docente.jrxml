<!-- Created with Jaspersoft Studio version 7.0.3.final using JasperReports Library version 7.0.3-41034ca841d452f3305ba55b9042260aaa1ab5dd  -->
<jasperReport name="reporte_evaluacion_docente" language="java" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="e633d264-7546-4cb2-bb8a-daaaaf311c1d">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="UPECDB"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="P_DEPEN_CODIGO" class="java.lang.String"/>
	<parameter name="P_INST_CODIGO" class="java.lang.String"/>
	<parameter name="P_CICLO_ACADEMICO" class="java.lang.String"/>
	<parameter name="P_LOGO_PATH" class="java.lang.String" forPrompting="false"/>
	<query language="sql"><![CDATA[SELECT NIVEL_CODIGO,
       MATERIA_CODIGO,
       CICLO_ACAD_CODIGO,
       DEPEN_CODIGO,
       TFINANCIA_CODIGO,
       TCICLOACAD_CODIGO,
       SIST_ESTUD_CODIGO,
       MODA_ESTUD_CODIGO,
       INST_CODIGO,
       DOCENTE_CEDULA,
       MATERIA,
       DOCENTES,
       ESTUDIANTES_ENCUESTA,
       ESTUDIANTES_MATRICULADOS,
       CALIFICACION_ESTUDIANTE,
       AUTO_EVALUACION,
       EVALUACION_PAR,
       EVALUACION_DIRECTIVO,
       (ESTUDIANTES_MATRICULADOS - ESTUDIANTES_ENCUESTA) AS ESTUDIANTES_SIN_EVALUAR,
       CALIFICACION_TOTAL
  FROM (SELECT NIVEL_CODIGO,
               MATERIA_CODIGO,
               CICLO_ACAD_CODIGO,
               DEPEN_CODIGO,
               TFINANCIA_CODIGO,
               TCICLOACAD_CODIGO,
               SIST_ESTUD_CODIGO,
               MODA_ESTUD_CODIGO,
               INST_CODIGO,
               DOCENTE_CEDULA,
               MATERIA,
               DOCENTES,
               ESTUDIANTES_ENCUESTA,
               ESTUDIANTES_MATRICULADOS,
               CALIFICACION_ESTUDIANTE,
               AUTO_EVALUACION,
               EVALUACION_PAR,
               EVALUACION_DIRECTIVO,
               ROUND (
                  ( ( (CALIFICACION_ESTUDIANTE
                       * EVA_PCK_EVALUACION.fun_porcen_calificacion (
                            EVA_PCK_EVALUACION.fun_encuesta_codigo (CICLO_ACAD_CODIGO, '002')))
                     + (EVALUACION_PAR
                        * EVA_PCK_EVALUACION.fun_porcen_calificacion (
                             EVA_PCK_EVALUACION.fun_encuesta_codigo (CICLO_ACAD_CODIGO, '001')))
                     + (AUTO_EVALUACION
                        * EVA_PCK_EVALUACION.fun_porcen_calificacion (
                             EVA_PCK_EVALUACION.fun_encuesta_codigo (CICLO_ACAD_CODIGO, '003')))
                     + ( (EVALUACION_DIRECTIVO
                          * EVA_PCK_EVALUACION.fun_porcen_calificacion (
                               EVA_PCK_EVALUACION.fun_encuesta_codigo (CICLO_ACAD_CODIGO, '004')))))
                   / 100), 2) AS CALIFICACION_TOTAL
          FROM (  SELECT DISTINCT
                         ATD.NIVEL_CODIGO,
                         ATD.MATERIA_CODIGO,
                         ATD.CICLO_ACAD_CODIGO,
                         ATD.DEPEN_CODIGO,
                         ATD.TFINANCIA_CODIGO,
                         ATD.TCICLOACAD_CODIGO,
                         ATD.SIST_ESTUD_CODIGO,
                         ATD.MODA_ESTUD_CODIGO,
                         ATD.INST_CODIGO,
                         ATD.DOCENTE_CEDULA,
                         ATM.DESCRIPCION AS MATERIA,
                         INS_PCK_GENERAL.FUN_NOMBRES_PERSONA (ATD.DOCENTE_CEDULA) AS DOCENTES,
                         EVA_PCK_EVALUACION.FUN_NUM_ESTUDIANTES_ENCUESTA (
                            ATD.MATERIA_CODIGO, ATD.DOCENTE_CEDULA, ATD.INST_CODIGO,
                            ATD.MODA_ESTUD_CODIGO, ATD.SIST_ESTUD_CODIGO, ATD.TCICLOACAD_CODIGO,
                            ATD.TFINANCIA_CODIGO, ATD.CICLO_ACAD_CODIGO, ATD.NIVEL_CODIGO, ATD.DEPEN_CODIGO) AS ESTUDIANTES_ENCUESTA,
                         EVA_PCK_EVALUACION.fun_num_estud_matriculados (
                            ATD.MATERIA_CODIGO, ATD.DOCENTE_CEDULA, ATD.INST_CODIGO,
                            ATD.MODA_ESTUD_CODIGO, ATD.SIST_ESTUD_CODIGO, ATD.TCICLOACAD_CODIGO,
                            ATD.TFINANCIA_CODIGO, ATD.CICLO_ACAD_CODIGO, ATD.NIVEL_CODIGO, ATD.DEPEN_CODIGO) AS ESTUDIANTES_MATRICULADOS,
                         EVA_PCK_EVALUACION.fun_calificacion_estu (
                            ATD.DOCENTE_CEDULA, ATD.INST_CODIGO, ATD.MODA_ESTUD_CODIGO,
                            ATD.SIST_ESTUD_CODIGO, ATD.TCICLOACAD_CODIGO, ATD.TFINANCIA_CODIGO,
                            ATD.DEPEN_CODIGO, ATD.CICLO_ACAD_CODIGO, ATD.MATERIA_CODIGO, ATD.NIVEL_CODIGO,
                            EVA_PCK_EVALUACION.fun_encuesta_codigo (ATD.CICLO_ACAD_CODIGO, '002'), '002') AS CALIFICACION_ESTUDIANTE,
                         EVA_PCK_EVALUACION.fun_auto_evaluacion (
                            ATD.DOCENTE_CEDULA, ATD.INST_CODIGO, ATD.MODA_ESTUD_CODIGO,
                            ATD.SIST_ESTUD_CODIGO, ATD.TCICLOACAD_CODIGO, ATD.TFINANCIA_CODIGO,
                            ATD.DEPEN_CODIGO, ATD.CICLO_ACAD_CODIGO, ATD.MATERIA_CODIGO, ATD.NIVEL_CODIGO,
                            EVA_PCK_EVALUACION.fun_encuesta_codigo (ATD.CICLO_ACAD_CODIGO, '003'), '003') AS AUTO_EVALUACION,
                         EVA_PCK_EVALUACION.fun_auto_evaluacion (
                            ATD.DOCENTE_CEDULA, ATD.INST_CODIGO, ATD.MODA_ESTUD_CODIGO,
                            ATD.SIST_ESTUD_CODIGO, ATD.TCICLOACAD_CODIGO, ATD.TFINANCIA_CODIGO,
                            ATD.DEPEN_CODIGO, ATD.CICLO_ACAD_CODIGO, ATD.MATERIA_CODIGO, ATD.NIVEL_CODIGO,
                            EVA_PCK_EVALUACION.fun_encuesta_codigo (ATD.CICLO_ACAD_CODIGO, '001'), '001') AS EVALUACION_PAR,
                         EVA_PCK_EVALUACION.fun_auto_evaluacion (
                            ATD.DOCENTE_CEDULA, ATD.INST_CODIGO, ATD.MODA_ESTUD_CODIGO,
                            ATD.SIST_ESTUD_CODIGO, ATD.TCICLOACAD_CODIGO, ATD.TFINANCIA_CODIGO,
                            ATD.DEPEN_CODIGO, ATD.CICLO_ACAD_CODIGO, ATD.MATERIA_CODIGO, ATD.NIVEL_CODIGO,
                            EVA_PCK_EVALUACION.fun_encuesta_codigo (ATD.CICLO_ACAD_CODIGO, '004'), '004') AS EVALUACION_DIRECTIVO
                    FROM    UPECDB.ACA_TAB_MATERIAS ATM
                         INNER JOIN UPECDB.ACA_TAB_DISTRIBUTIVOS ATD
                         ON (ATM.NIVEL_CODIGO = ATD.NIVEL_CODIGO) AND (ATM.CODIGO = ATD.MATERIA_CODIGO)
                   WHERE     (ATD.ESTADO = 'A')
                         AND (ATD.DEPEN_CODIGO = $P{P_DEPEN_CODIGO})
                         AND (ATD.INST_CODIGO = $P{P_INST_CODIGO})
                         AND (ATD.CICLO_ACAD_CODIGO = $P{P_CICLO_ACADEMICO})
                ORDER BY ATD.NIVEL_CODIGO, 12))]]></query>
	<field name="NIVEL_CODIGO" class="java.lang.String"/>
	<field name="DOCENTE_CEDULA" class="java.lang.String"/>
	<field name="DOCENTES" class="java.lang.String"/>
