			<element kind="textField" uuid="c24a2dc9-6e3e-4b68-ab6a-66b96ed5e390" stretchType="ElementGroupHeight" x="620" y="0" width="60" height="20" fontSize="8.0" textAdjust="StretchHeight" pattern="#,##0.00#" blankWhenNull="true" hTextAlign="Right" vTextAlign="Middle">
