	<field name="ESTUDIANTES_ENCUESTA" class="java.math.BigDecimal"/>
	<field name="ESTUDIANTES_MATRICULADOS" class="java.math.BigDecimal"/>
	<field name="ESTUDIANTES_SIN_EVALUAR" class="java.math.BigDecimal"/>
	<field name="CALIFICACION_ESTUDIANTE" class="java.math.BigDecimal"/>
	<field name="AUTO_EVALUACION" class="java.math.BigDecimal"/>
	<field name="EVALUACION_PAR" class="java.math.BigDecimal"/>
	<field name="EVALUACION_DIRECTIVO" class="java.math.BigDecimal"/>
	<field name="CALIFICACION_TOTAL" class="java.math.BigDecimal"/>
